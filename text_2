import streamlit as st
import sqlite3
import pandas as pd
import plotly.express as px

st.set_page_config(page_title="Мониторинг качества данных", layout="wide")
st.title("Дашборд контроля качества данных")

conn = sqlite3.connect('data/traffic.db')

df_log = pd.read_sql_query("""
    SELECT * FROM data_quality_log 
    ORDER BY timestamp DESC 
    LIMIT 100
""", conn)

if df_log.empty:
    st.warning("Нет данных о качестве")
    st.stop()

st.subheader("Последние проверки")
st.dataframe(df_log[['timestamp', 'check_name', 'source', 'status', 'details']])

st.subheader("Статус проверок по дням")
df_log['date'] = pd.to_datetime(df_log['timestamp']).dt.date
status_counts = df_log.groupby(['date', 'status']).size().reset_index(name='count')
fig = px.bar(status_counts, x='date', y='count', color='status',
             title="Количество проверок по статусу")
st.plotly_chart(fig, use_container_width=True)

st.subheader("Проверки с ошибками (FAIL)")
fails = df_log[df_log['status'] == 'FAIL']
st.write(fails[['timestamp', 'check_name', 'details']])

conn.close()


