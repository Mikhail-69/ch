import sqlite3
import pandas as pd
from datetime import datetime

DB_PATH = 'data/traffic.db'

def run_batch_quality_checks():
    conn = sqlite3.connect(DB_PATH)
    
    # 1. ПРОВЕРКА ПОЛНОТЫ (нет ли пустых значений)
    df = pd.read_sql_query("SELECT confidence, vehicle_type FROM detections", conn)
    null_conf_pct = df['confidence'].isnull().mean() * 100
    null_type_pct = df['vehicle_type'].isnull().mean() * 100
    
    status_conf = 'PASS' if null_conf_pct < 5 else 'FAIL'
    conn.execute("""
        INSERT INTO data_quality_log (timestamp, check_name, source, status, details, threshold)
        VALUES (?, ?, ?, ?, ?, ?)
    """, (datetime.now().isoformat(), 'null_confidence', 'batch', status_conf,
          f'{null_conf_pct:.1f}% пропусков', 5))
    
    status_type = 'PASS' if null_type_pct < 5 else 'FAIL'
    conn.execute("""
        INSERT INTO data_quality_log (timestamp, check_name, source, status, details, threshold)
        VALUES (?, ?, ?, ?, ?, ?)
    """, (datetime.now().isoformat(), 'null_vehicle_type', 'batch', status_type,
          f'{null_type_pct:.1f}% пропусков', 5))
    
    # 2. ПРОВЕРКА ДУБЛИКАТОВ
    cur = conn.cursor()
    cur.execute("""
        SELECT COUNT(*) as total, COUNT(DISTINCT frame_id || timestamp) as unique_count
        FROM detections
    """)
    total, unique = cur.fetchone()
    dup_pct = (total - unique) / total * 100 if total > 0 else 0
    dup_status = 'WARN' if dup_pct > 1 else 'PASS'
    conn.execute("""
        INSERT INTO data_quality_log (timestamp, check_name, source, status, details, threshold)
        VALUES (?, ?, ?, ?, ?, ?)
    """, (datetime.now().isoformat(), 'duplicate_rows', 'batch', dup_status,
          f'{dup_pct:.2f}% дубликатов', 1))
    
    # 3. ПРОВЕРКА АНОМАЛИЙ (резкие скачки интенсивности)
    metrics_df = pd.read_sql_query("""
        SELECT total_vehicles FROM metrics 
        WHERE minute_bucket >= datetime('now', '-1 hour')
    """, conn)
    if not metrics_df.empty:
        avg_intensity = metrics_df['total_vehicles'].mean()
        max_intensity = metrics_df['total_vehicles'].max()
        if max_intensity > avg_intensity * 3:
            conn.execute("""
                INSERT INTO data_quality_log (timestamp, check_name, source, status, details)
                VALUES (?, ?, ?, ?, ?)
            """, (datetime.now().isoformat(), 'intensity_anomaly', 'batch', 'WARN',
                  f'Максимум {max_intensity} > {avg_intensity:.1f} * 3'))
    
    conn.commit()
    conn.close()
    print("Пакетные проверки качества завершены")

if __name__ == "__main__":
    run_batch_quality_checks()



