from airflow import DAG
from airflow.operators.bash import BashOperator
from datetime import datetime, timedelta

default_args = {
    'owner': 'champion',
    'start_date': datetime(2026, 4, 1),
    'retries': 1,
    'retry_delay': timedelta(minutes=5),
}

with DAG(
    dag_id='traffic_pipeline',
    default_args=default_args,
    schedule_interval='*/15 * * * *',
    catchup=False,
) as dag:

    # Задача 1: детекция и метрики
    run_detection = BashOperator(
        task_id='run_full_pipeline',
        bash_command='python3 /opt/airflow/project/run_full_pipeline.py',
    )

    # Задача 2: обучение модели (запускается после детекции)
    train_model = BashOperator(
        task_id='train_model',
        bash_command='python3 /opt/airflow/project/train_model.py',
    )

    # Задача 3: очистка (удаление дубликатов и т.д.)
    clean_data = BashOperator(
        task_id='clean_data',
        bash_command='python3 /opt/airflow/project/clean_data.py', 
    )

    # Задача 4: обогащение (добавить час, день недели)
    enrich_data = BashOperator(
        task_id='enrich_data',
        bash_command='python3 /opt/airflow/project/enrich_data.py',  
    )
	# НОВАЯ ЗАДАЧА: проверки качества
    quality_checks = BashOperator(
        task_id='quality_checks_batch',
        bash_command='python3 /opt/airflow/project/quality_checks_batch.py',
    )

    # Указываем порядок: сначала детекция, потом всё остальное
    run_detection >> train_model >> clean_data >> enrich_data >> quality_checks

